{
  "extraKnownMarketplaces": {
    "nixtla-dev-marketplace": {
      "source": {
        "source": "github",
        "repo": "jeremylongshore/plugins-nixtla"
      }
    }
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-compact.sh"
          }
        ]
      }
    ]
  },
  "readAfterCompact": [
    "scripts/validate_skills.py",
    "000-docs/000a-skills-schema/SKILLS-STANDARD-COMPLETE.md"
  ]
}
