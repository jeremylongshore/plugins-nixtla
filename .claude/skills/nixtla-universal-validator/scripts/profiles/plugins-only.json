{
  "name": "plugins-only",
  "description": "Validates plugins; optionally runs pytest.",
  "phases": [
    {
      "name": "structural",
      "checks": [
        {
          "name": "plugins.validate",
          "command": ["bash", "004-scripts/validate-all-plugins.sh", "{target}"],
          "cwd": "{repo_root}",
          "severity": "error"
        }
      ]
    },
    {
      "name": "behavioral",
      "checks": [
        {
          "name": "tests.pytest",
          "command": ["pytest", "-q"],
          "cwd": "{repo_root}",
          "severity": "error",
          "when": { "flag": "run_tests", "equals": true }
        }
      ]
    }
  ]
}

