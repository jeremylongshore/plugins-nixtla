# Nixtla Search-to-Slack Plugin Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# ==================================================
# SLACK CONFIGURATION (REQUIRED)
# ==================================================
# Bot token from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here

# Default channel for digest posts (can be overridden per topic)
SLACK_CHANNEL=#nixtla-updates

# ==================================================
# LLM CONFIGURATION (ONE REQUIRED - FREE OPTIONS AVAILABLE!)
# ==================================================
# Priority: Free options are checked first, then paid options

# Option 1: Google Gemini (FREE via AI Studio) - RECOMMENDED
# Get your free key at: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# Option 2: Groq (FREE tier available) - Fast inference!
# Get your free key at: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key-here

# Option 3: OpenAI (PAID - $0.002-0.06 per 1K tokens)
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Option 4: Anthropic Claude (PAID - $0.008-0.024 per 1K tokens)
# Get key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Advanced: Use custom LLM provider (see documentation)
# CUSTOM_LLM_PROVIDER=my-custom-provider
# CUSTOM_LLM_ENDPOINT=https://my-llm-endpoint.com/v1/chat

# LLM Model selection (optional, sensible defaults provided)
# For Gemini: gemini-pro (default, free)
# For Groq: mixtral-8x7b-32768 (default, free, fast)
# For OpenAI: gpt-3.5-turbo (default) or gpt-4
# For Anthropic: claude-3-haiku-20240307 (default) or claude-3-opus-20240229
# LLM_MODEL=model-name-here

# ==================================================
# WEB SEARCH PROVIDER (ONE REQUIRED - FREE OPTIONS AVAILABLE!)
# ==================================================
# Priority: Free options are checked first, then paid options

# Option 1: Brave Search (FREE - 2,000 queries/month) - RECOMMENDED
# Get your free key at: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-api-key-here

# Option 2: Google Custom Search (FREE - 100 queries/day)
# Setup: https://developers.google.com/custom-search/v1/introduction
# Step 1: Get API key at: https://console.cloud.google.com/apis/credentials
# Step 2: Create search engine at: https://cse.google.com/cse/all
# GOOGLE_API_KEY=your-google-api-key-here
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# Option 3: Bing Web Search (FREE - 1,000 queries/month)
# Get your free key at: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# BING_API_KEY=your-bing-api-key-here

# Option 4: DuckDuckGo (100% FREE - No API key needed, but limited)
# Note: Uses Instant Answer API with limited search capabilities
# USE_DUCKDUCKGO=true

# Option 5: SerpAPI (PAID - $50/month minimum)
# Get key at: https://serpapi.com/
# SERP_API_KEY=your-serpapi-key-here

# ==================================================
# GITHUB SEARCH (REQUIRED - FREE!)
# ==================================================
# GitHub token for API access (needs repo read permissions)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here

# ==================================================
# OPTIONAL CONFIGURATION
# ==================================================
# Debug mode (increases logging verbosity)
DEBUG=false

# Maximum items to include in digest
MAX_ITEMS_PER_DIGEST=10

# Cache directory (for development only)
# CACHE_DIR=/tmp/nixtla-search-cache

# Relevance score threshold (0-100)
# MIN_RELEVANCE_SCORE=50

# Time range for searches (e.g., "24h", "7d", "30d")
# DEFAULT_TIME_RANGE=7d

# ==================================================
# ADVANCED CONFIGURATION (USUALLY NOT NEEDED)
# ==================================================
# API timeouts (in seconds)
# API_TIMEOUT=30

# Retry configuration
# MAX_RETRIES=3
# RETRY_BACKOFF_FACTOR=2

# Slack rate limiting
# SLACK_RATE_LIMIT_DELAY=1

# ==================================================
# NOTES
# ==================================================
# 1. This is an EXAMPLE file for the MVP plugin
# 2. The plugin is a construction kit, not a production service
# 3. You must provide your own API keys and tokens
# 4. Costs will be incurred for API usage (LLM, search)
# 5. This is not endorsed or operated by Nixtla