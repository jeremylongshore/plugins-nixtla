# TimeGPT Lab – Example Environment File
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored and will NOT be committed.

# Nixtla TimeGPT API Key (required)
# Obtain from: https://dashboard.nixtla.io/
NIXTLA_TIMEGPT_API_KEY=your_timegpt_api_key_here

# Environment mode (optional)
# Values: dev, demo, prod
NIXTLA_ENV=dev
