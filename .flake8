[flake8]
max-line-length = 100
extend-ignore = E501
exclude =
    .git,
    .venv,
    .venv-*,
    venv,
    build,
    dist,
    __pycache__,
    .audit-harness,
    009-temp-data,
    010-archive

# Template files have intentional undefined names (placeholders for users)
per-file-ignores =
    skills-pack/.claude/skills/*/resources/TEMPLATES/*.py:F821
