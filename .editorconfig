# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 80

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2
insert_final_newline = false

[*.md]
trim_trailing_whitespace = false
max_line_length = 80

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

[*.{csv,tsv}]
insert_final_newline = false
trim_trailing_whitespace = false

[{package.json,.travis.yml}]
indent_size = 2